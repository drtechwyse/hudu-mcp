# HUDU MCP Server Configuration
# Copy this file to .env and fill in your actual values

# Your HUDU API key (found in HUDU under Admin > API Keys)
HUDU_API_KEY=
# Your HUDU instance base URL - DOMAIN ONLY, do not include /api/v1
# Example: https://your-company.huducloud.com (NOT https://your-company.huducloud.com/api/v1)
HUDU_BASE_URL=

# Paths to your TLS certificate and private key files (required for HTTPS)
# Example: /etc/ssl/certs/server.crt and /etc/ssl/private/server.key


#MCP Server access token
MCP_AUTH_TOKEN= 

HOST=127.0.0.1
